{
  "name": "apex-call-graph",
  "displayName": "Apex Call Graph",
  "description": "Trace callers and callees of Apex methods, inspect arguments, and assess signature-change impact across Apex, Flow, LWC, Aura and Visualforce. Offline static analysis: real Apex parser, no org connection, no language server.",
  "version": "0.18.0",
  "publisher": "Skrety",
  "license": "MIT",
  "icon": "plugin-icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "keywords": [
    "apex",
    "salesforce",
    "call hierarchy",
    "callers",
    "references"
  ],
  "main": "./extension.js",
  "scripts": {
    "build": "node --check extension.js && node --check apexindex.js",
    "test": "node test.js",
    "verify": "node dev/verify.js",
    "vscode:prepublish": "npm run build && node dev/sanitize-dependency-metadata.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "apexTrace.traceCallers",
        "title": "Who Calls This?",
        "category": "Apex Call Graph",
        "icon": "$(call-incoming)"
      },
      {
        "command": "apexTrace.traceCallees",
        "title": "What Does This Call?",
        "category": "Apex Call Graph",
        "icon": "$(call-outgoing)"
      },
      {
        "command": "apexTrace.impactAnalysis",
        "title": "Impact of Changing This Method",
        "category": "Apex Call Graph",
        "icon": "$(warning)"
      },
      {
        "command": "apexTrace.toggleDirection",
        "title": "Switch Trace Direction",
        "category": "Apex Call Graph",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "apexTrace.toggleOrientation",
        "title": "Toggle orientation: target-first / entry-first",
        "category": "Apex Call Graph",
        "icon": "$(list-tree)"
      },
      {
        "command": "apexTrace.showPathMap",
        "title": "Show Path Map",
        "category": "Apex Call Graph",
        "icon": "$(map)"
      },
      {
        "command": "apexTrace.refreshPathMap",
        "title": "Refresh Path Map",
        "category": "Apex Call Graph",
        "icon": "$(map)"
      },
      {
        "command": "apexTrace.showEntryCatalog",
        "title": "Show Entry Points",
        "category": "Apex Call Graph",
        "icon": "$(refresh)"
      },
      {
        "command": "apexTrace.copyDiagnostics",
        "title": "Copy Diagnostics (counts only)",
        "category": "Apex Call Graph"
      },
      {
        "command": "apexTrace.clearCache",
        "title": "Clear Cache",
        "category": "Apex Call Graph"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "apexTrace.traceCallers",
          "group": "apextrace@1",
          "when": "resourceExtname == .cls || resourceExtname == .trigger"
        },
        {
          "command": "apexTrace.traceCallees",
          "group": "apextrace@2",
          "when": "resourceExtname == .cls || resourceExtname == .trigger"
        },
        {
          "command": "apexTrace.impactAnalysis",
          "group": "apextrace@3",
          "when": "resourceExtname == .cls || resourceExtname == .trigger"
        },
        {
          "command": "apexTrace.showPathMap",
          "group": "apextrace@4",
          "when": "resourceExtname == .cls || resourceExtname == .trigger"
        }
      ],
      "view/title": [
        {
          "command": "apexTrace.refreshPathMap",
          "group": "navigation",
          "when": "view == apexTraceView && apexTrace.mode != 'impact'"
        },
        {
          "command": "apexTrace.toggleDirection",
          "group": "navigation",
          "when": "view == apexTraceView && apexTrace.hasResults && apexTrace.mode != 'impact'"
        },
        {
          "command": "apexTrace.toggleOrientation",
          "group": "navigation",
          "when": "view == apexTraceView && apexTrace.hasResults && apexTrace.mode != 'impact' && apexTrace.direction == 'callers'"
        },
        {
          "command": "apexTrace.showEntryCatalog",
          "group": "navigation",
          "when": "view == apexTraceEntriesView"
        }
      ],
      "view/item/context": [
        {
          "command": "apexTrace.traceCallees",
          "group": "inline",
          "when": "view == apexTraceEntriesView && viewItem == apexTraceEntryCatalogEntry"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "apexTraceView",
          "name": "Apex Call Graph: Callers",
          "contextualTitle": "Apex Call Graph"
        },
        {
          "id": "apexTraceEntriesView",
          "name": "Apex Call Graph: Entry Points",
          "contextualTitle": "Apex Call Graph"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "apexTraceView",
        "contents": "Trace who calls an Apex class or method, what it calls out to, or assess a method-signature change.\n[Who Calls This?](command:apexTrace.traceCallers)\n[What Does This Call?](command:apexTrace.traceCallees)\n[Impact of Changing This Method](command:apexTrace.impactAnalysis)\n[Open Path Map](command:apexTrace.showPathMap)"
      },
      {
        "view": "apexTraceEntriesView",
        "contents": "Scan the workspace to list every entry point.\n[Show Entry Points](command:apexTrace.showEntryCatalog)"
      }
    ],
    "configuration": {
      "title": "Apex Call Graph",
      "properties": {
        "apexCallGraph.initialDepth": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 8,
          "description": "How many levels deep a trace expands automatically before you have to click to load more. Lower values keep traces fast and readable on large orgs; raise it for smaller ones where you usually want the whole picture at once."
        },
        "apexCallGraph.expandStep": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 4,
          "description": "How many extra levels a single click loads when you expand a collapsed (\"+N more\") node in the tree view or the Path Map."
        },
        "apexCallGraph.maxDepth": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 20,
          "description": "Hard ceiling on trace depth, however far you click to expand."
        },
        "apexCallGraph.maxNodes": {
          "type": "number",
          "default": 2000,
          "minimum": 100,
          "maximum": 20000,
          "description": "Fair cap on the total number of nodes a single trace will materialize, to keep very large or highly-connected orgs responsive."
        },
        "apexCallGraph.excludeGlobs": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "type": "string",
            "maxLength": 2048
          },
          "default": [],
          "description": "Up to 64 extra workspace-relative glob patterns to exclude identically from full and incremental scanning. Supports *, ?, segment **, braces, and character classes; a directory match excludes its descendants. Combined expansion work is bounded for responsiveness."
        },
        "apexCallGraph.showUnconfirmed": {
          "type": "string",
          "enum": ["rollup", "hide", "expand"],
          "enumDescriptions": [
            "Group approximate (unconfirmed) callers/callees under one collapsed \"N possible callers/callees (unconfirmed)\" node.",
            "Hide approximate (unconfirmed) callers/callees entirely -- only confirmed edges are shown.",
            "Show approximate (unconfirmed) callers/callees inline, eagerly expanded, as in earlier versions."
          ],
          "default": "rollup",
          "description": "How to display approximate (unconfirmed) callers/callees -- e.g. resolved via interface/override/unique-name/ambiguous/lexical/dynamic matching rather than a direct, confirmed call."
        }
      }
    }
  },
  "dependencies": {
    "@apexdevtools/apex-parser": "^5.1.0"
  }
}
